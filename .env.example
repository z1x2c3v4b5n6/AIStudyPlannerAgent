# Copy this file to .env and replace the example passwords before starting Compose.
DB_USERNAME=ai_study
DB_PASSWORD=change_me_app_password
MYSQL_ROOT_PASSWORD=change_me_root_password

FRONTEND_PORT=5173
BACKEND_PORT=8080
APP_CORS_ALLOWED_ORIGIN=http://localhost:5173

# AI is disabled by default. Leave the key empty unless AI_ENABLED=true.
AI_ENABLED=false
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
